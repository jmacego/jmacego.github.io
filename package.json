{
  "name": "jmaclabs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "preview:e2e": "astro preview --host 127.0.0.1 --port 4173",
    "preview:build": "pnpm build && pnpm preview",
    "preview:watch": "pnpm dev",
    "astro": "astro",
    "test:image-frontmatter": "node --test scripts/migrate-image-frontmatter.test.mjs",
    "test:html-parity": "node scripts/check-html-parity.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "validate": "./scripts/validate.sh"
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "3.7.0",
    "astro": "^5.18.1",
    "marked": "^17.0.4"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.7",
      "devalue": ">=5.6.3"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
