---
import { site } from "../siteData";
import { buildSeo } from "../utils/seo";
import "../assets/styles.css";

const {
  title,
  description,
  frontmatter,
  currentPath,
  socialImage,
  socialImageAlt,
  ogImage,
  ogImageAlt,
  ogType,
  publishedTime,
  author,
  robots,
} = Astro.props;
const pathname = Astro.url.pathname;
const resolvedTitle = title ?? frontmatter?.title;
const resolvedDescription = description ?? frontmatter?.description;
const pageTitle = resolvedTitle ? `${resolvedTitle} | ${site.title}` : site.title;
const pageDescription = resolvedDescription ?? site.description;
const seo = buildSeo({
  currentPath: currentPath ?? pathname,
  siteUrl: site.url,
  siteName: site.title,
  socialImage: socialImage ?? ogImage,
  socialImageAlt: socialImageAlt ?? ogImageAlt,
  defaultSocialImage: site.defaultSocialImage,
  defaultSocialImageAlt: site.defaultSocialImageAlt,
  ogType,
});

const isActive = (href) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={seo.canonicalUrl} />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:url" content={seo.canonicalUrl} />
    {seo.socialImageUrl && <meta property="og:image" content={seo.socialImageUrl} />}
    {seo.socialImageAlt && <meta property="og:image:alt" content={seo.socialImageAlt} />}
    {seo.ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {seo.ogType === "article" && author && (
      <meta property="article:author" content={author} />
    )}
    <meta name="twitter:card" content={seo.twitterCard} />
    {site.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
    {(author || site.twitterHandle) && <meta name="twitter:creator" content={site.twitterHandle} />}
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {seo.socialImageUrl && <meta name="twitter:image" content={seo.socialImageUrl} />}
    {seo.socialImageAlt && <meta name="twitter:image:alt" content={seo.socialImageAlt} />}
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css"
      integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T"
      crossorigin="anonymous"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png" />
    <link rel="manifest" href="/assets/images/site.webmanifest" />
    <link rel="mask-icon" href="/assets/images/safari-pinned-tab.svg" color="#5bbad5" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fcfcfd" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0e0f10" />
    {site.cloudflareAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: site.cloudflareAnalyticsToken })}
      ></script>
    )}
  </head>
  <body>
    <span id="top-of-page"></span>
    <div class="container">
      <header class="blog-header py-3">
        <div class="blog-header-inner">
          <a
            class="blog-header-logo"
            href="/"
            aria-label={`${site.title} home`}
          >
            <picture>
              <source
                srcset="/assets/images/branding/logo-white-text.png"
                media="(prefers-color-scheme: dark)"
              />
              <img
                src="/assets/images/branding/logo-black-text.png"
                alt={site.title}
              />
            </picture>
          </a>
        </div>
      </header>

      <div class="nav-scroller py-1 mb-2">
        <nav class="site-nav" aria-label="Primary">
          <a class:list={["site-nav-link", isActive("/") && "is-current"]} aria-current={isActive("/") ? "page" : undefined} href="/">Home</a>
          <a class:list={["site-nav-link", isActive("/blog/") && "is-current"]} aria-current={isActive("/blog/") ? "page" : undefined} href="/blog/">Posts</a>
          <a class:list={["site-nav-link", isActive("/projects/") && "is-current"]} aria-current={isActive("/projects/") ? "page" : undefined} href="/projects/">Projects</a>
          <a class:list={["site-nav-link", isActive("/resume/") && "is-current"]} aria-current={isActive("/resume/") ? "page" : undefined} href="/resume/">Resumé</a>
          <a class:list={["site-nav-link", isActive("/about/") && "is-current"]} aria-current={isActive("/about/") ? "page" : undefined} href="/about/">About Me</a>
        </nav>
      </div>

      <main class="site-main">
        <div class="content-rail">
          <slot />
        </div>
      </main>

      <footer class="blog-footer">
        <div class="content-rail">
          <div class="about-author">
            <img
              src="/assets/images/jmac-profile.jpg"
              alt="John MacDonald"
              class="about-author-image"
            />
            <div class="about-author-copy">
              <p class="lead">About John</p>
              <p>
                John MacDonald is a Fractional CTO and advisor focused on AI strategy, architecture,
                and technical leadership. He's also a licensed pilot, recovering entrepreneur, and
                occasional tinkerer. For the full story, visit the <a href="/about/">About Me</a> page.
              </p>
            </div>
          </div>
        </div>
      </footer>
    </div>

    {site.gaId && (
        <div id="cookie-notice">
          <span>We would like to use Google Analytics to monitor website utilization.</span>
          <a href="#" id="cookie-notice-accept" class="btn btn-primary btn-sm">Approve</a>
          <a href="#" id="cookie-notice-deny" class="btn btn-outline-primary btn-sm">Deny</a>
        </div>
      )}

    {site.gaId && (
      <script is:inline define:vars={{ gaId: site.gaId }}>
        const cookieName = "cookie-notice-option";

        function createCookie(name, value, days) {
          let expires = "";
          if (days) {
            const date = new Date();
            date.setTime(date.getTime() + days * 24 * 60 * 60 * 1000);
            expires = "; expires=" + date.toUTCString();
          }
          document.cookie = name + "=" + value + expires + "; path=/";
        }

        function readCookie(name) {
          const nameEQ = name + "=";
          const ca = document.cookie.split(";");
          for (let i = 0; i < ca.length; i += 1) {
            let c = ca[i];
            while (c.charAt(0) === " ") c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
          }
          return null;
        }

        function loadAnalytics() {
          const script = document.createElement("script");
          script.async = true;
          script.src = "https://www.googletagmanager.com/gtag/js?id=" + gaId;
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag("js", new Date());
          gtag("config", gaId, { anonymize_ip: true });
        }

        const notice = document.getElementById("cookie-notice");
        const option = readCookie(cookieName);

        if (option === "true") {
          loadAnalytics();
        } else if (option !== "false" && notice) {
          notice.style.display = "block";
        }

        const accept = document.getElementById("cookie-notice-accept");
        const deny = document.getElementById("cookie-notice-deny");

        if (accept) {
          accept.addEventListener("click", (event) => {
            event.preventDefault();
            createCookie(cookieName, "true", 31);
            if (notice) notice.style.display = "none";
            loadAnalytics();
          });
        }

        if (deny) {
          deny.addEventListener("click", (event) => {
            event.preventDefault();
            createCookie(cookieName, "false", 31);
            if (notice) notice.style.display = "none";
          });
        }
      </script>
    )}
  </body>
</html>
