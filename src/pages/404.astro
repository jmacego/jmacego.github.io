---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for is not available at this address."
  robots="noindex, nofollow"
>
  <section class="error-shell">
    <p class="section-kicker">404</p>

    <picture class="error-logo">
      <source
        srcset="/assets/images/branding/logo-white-text.png"
        media="(prefers-color-scheme: dark)"
      />
      <img src="/assets/images/branding/logo-black-text.png" alt="John MacDonald" />
    </picture>

    <h1 class="error-title">Sorry, that page is missing.</h1>
    <p class="error-lede">
      The link may be out of date, the address may have a typo, or the page may have moved.
    </p>

    <div class="error-actions">
      <a class="btn btn-primary" href="/">Go home</a>
      <a class="btn btn-outline-primary" href="/blog/">Read posts</a>
      <a class="btn btn-outline-primary" href="/projects/">Browse projects</a>
    </div>

    <div class="error-help">
      <p>Here are a few good next steps:</p>
      <ul>
        <li>Check the address for a typo.</li>
        <li>Head home or browse recent writing.</li>
        <li>If you were looking for technical work, start with projects.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
