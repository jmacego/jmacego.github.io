---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatDate,
  getEntryDate,
  getExcerpt,
  getExcerptText,
  isPublished,
  normalizeImagePath,
  normalizeThumbnailPath,
  sortByDateDesc,
  stripDatePrefix,
} from "../utils/content";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", isPublished)).sort(sortByDateDesc);
const projects = (await getCollection("projects", isPublished)).sort(sortByDateDesc);

const heroPost = posts[0];
const secondaryPost = posts[1];
const featuredProject = projects[0];

const heroImage = normalizeImagePath(heroPost?.data.image?.src);
const secondaryImage = normalizeThumbnailPath(secondaryPost?.data.image?.src);
const projectImage = normalizeThumbnailPath(featuredProject?.data.image?.src);

const heroExcerpt = heroPost ? getExcerpt(heroPost.body) : "";
const secondaryExcerpt = secondaryPost ? getExcerpt(secondaryPost.body) : "";
const projectExcerpt = featuredProject ? getExcerpt(featuredProject.body) : "";

const pageDescription = heroPost
  ? getExcerptText(heroPost.body)
  : "John MacDonald — Networking, Infrastructure, and Automation";

const heroDate = heroPost ? getEntryDate(heroPost) : undefined;
const secondaryDate = secondaryPost ? getEntryDate(secondaryPost) : undefined;
const projectDate = featuredProject ? getEntryDate(featuredProject) : undefined;
---

<BaseLayout
  title="John MacDonald — Fractional CTO, Advisor, Speaker"
  description={pageDescription}
  socialImage={heroImage}
  socialImageAlt={heroPost?.data.image?.alt ?? heroPost?.data.title}
>
  <div class="jumbotron p-4 p-md-5 text-white home-hero">
    {heroPost && (
      <>
        <div class="home-hero-header">
          <p class="section-kicker section-kicker--signal">Latest post</p>
          <h1 class="display-4 home-hero-title">
            <a class="text-white" href={`/blog/${stripDatePrefix(heroPost.slug)}/`}>
              {heroPost.data.title}
            </a>
          </h1>
        </div>

        <div class:list={["home-hero-body", !heroImage && "home-hero-body--single"]}>
          <div class="home-hero-copy">
            {heroDate && <div class="mb-3 text-muted">{formatDate(heroDate)}</div>}
            <div class="home-hero-excerpt lead my-3" set:html={heroExcerpt} />
            <p class="lead mb-0">
              <a
                href={`/blog/${stripDatePrefix(heroPost.slug)}/`}
                title={heroPost.data.title}
                class="hero-link"
              >
                Continue reading
              </a>
            </p>
          </div>

          {heroImage && (
            <div class="home-hero-media">
              <a class="feature-thumb d-block" href={`/blog/${stripDatePrefix(heroPost.slug)}/`}>
                <img
                  src={heroImage}
                  alt={heroPost.data.image?.alt ?? heroPost.data.title}
                />
              </a>
            </div>
          )}
        </div>
      </>
    )}
  </div>

  <div class="home-feature-grid">
      <div class="feature-card border rounded overflow-hidden shadow-sm position-relative">
        {secondaryPost && (
          <>
            <div class="feature-card-header p-4">
              <p class="section-kicker">Posts</p>
              <h2 class="feature-card-title mb-0">
                <a href={`/blog/${stripDatePrefix(secondaryPost.slug)}/`}>
                  {secondaryPost.data.title}
                </a>
              </h2>
            </div>

            <div class:list={["feature-card-body", !secondaryImage && "feature-card-body--single"]}>
              <div class="feature-card-copy p-4 pt-0">
                {secondaryDate && <div class="mb-1 text-muted">{formatDate(secondaryDate)}</div>}
                <div class="mb-auto" set:html={secondaryExcerpt} />
                <a
                  class="card-link stretched-link"
                  href={`/blog/${stripDatePrefix(secondaryPost.slug)}/`}
                  title={secondaryPost.data.title}
                >
                  Continue reading
                </a>
              </div>

              {secondaryImage && (
                <div class="feature-card-media d-none d-lg-block feature-thumb">
                  <img
                    src={secondaryImage}
                    alt={secondaryPost.data.image?.alt ?? secondaryPost.data.title}
                  />
                </div>
              )}
            </div>
          </>
        )}
      </div>
      <div class="feature-card border rounded overflow-hidden shadow-sm position-relative">
        {featuredProject && (
          <>
            <div class="feature-card-header p-4">
              <p class="section-kicker">Projects</p>
              <h2 class="feature-card-title mb-0">
                <a href={`/projects/${stripDatePrefix(featuredProject.slug)}/`}>
                  {featuredProject.data.title}
                </a>
              </h2>
            </div>

            <div class:list={["feature-card-body", !projectImage && "feature-card-body--single"]}>
              <div class="feature-card-copy p-4 pt-0">
                {projectDate && <div class="mb-1 text-muted">{formatDate(projectDate)}</div>}
                <div class="mb-auto" set:html={projectExcerpt} />
                <a
                  class="card-link stretched-link"
                  href={`/projects/${stripDatePrefix(featuredProject.slug)}/`}
                  title={featuredProject.data.title}
                >
                  Continue reading
                </a>
              </div>

              {projectImage && (
                <div class="feature-card-media d-none d-lg-block feature-thumb">
                  <img
                    src={projectImage}
                    alt={featuredProject.data.image?.alt ?? featuredProject.data.title}
                  />
                </div>
              )}
            </div>
          </>
        )}
      </div>
  </div>
</BaseLayout>
