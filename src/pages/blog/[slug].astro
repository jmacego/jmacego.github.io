---
import PostLayout from "../../layouts/PostLayout.astro";
import {
  getExcerptText,
  isPublishedOrDraftInDev,
  normalizeImagePath,
  stripDatePrefix,
} from "../../utils/content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", isPublishedOrDraftInDev);
  return posts.map((post) => ({
    params: { slug: stripDatePrefix(post.slug) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const description = post.data.description ?? post.data.summary ?? getExcerptText(post.body);
const imagePath = normalizeImagePath(post.data.image?.src);
---

<PostLayout
  title={post.data.title}
  description={description}
  date={post.data.date}
  image={post.data.image}
  categories={post.data.categories}
  socialImage={imagePath}
  socialImageAlt={post.data.image?.alt ?? post.data.title}
  ogType="article"
  publishedTime={post.data.date?.toISOString()}
  author={post.data.author}
>
  <Content />
</PostLayout>
